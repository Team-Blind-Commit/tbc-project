# Copy this file to .env.local and fill in your values:
#   copy .env.example .env.local (Windows)
# Restart npm run dev after saving .env.local (stop any old dev server on port 3000).

# ElevenLabs Conversational AI (Voice Coach)
# 1. Create agent at elevenlabs.io/app/conversational-ai
# 2. Security → enable "Public" (REQUIRED — without this, WebRTC negotiation fails)
# 3. Add dynamic variables: mode (string), memory (string)
# 4. System prompt: see lib/voice-coach-agent-prompt.ts
# 5. API key: Profile → API Keys → enable "Conversational AI" for signed URLs
# Keep keys server-side only (no NEXT_PUBLIC_ prefix). Restart npm run dev after edits.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_COACH_AGENT_ID=

# Post-session AI summaries and homework tasks
OPENAI_API_KEY=
GROQ_API_KEY=

# Sessions, coach memory, dashboard homework (run supabase/migrations/*.sql)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
